// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
  ARCHIVED
}

model Lead {
  leadId       String      @id
  createdAt    DateTime    @default(now())
  fullName     String
  phoneDigits  String
  email        String

  address      String      @default("UNKNOWN")
  city         String      @default("UNKNOWN")

  service      String
  details      String?
  status       LeadStatus  @default(NEW)
  contactedAt  DateTime?
  adminNotes   String?
  archivedAt   DateTime?

  // Audit trail
  events       LeadEvent[]
}

model LeadEvent {
  id        Int      @id @default(autoincrement())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [leadId], onDelete: Cascade)
  createdAt DateTime @default(now())
  action    String   // e.g. "CREATED", "STATUS_CHANGE", "NOTES_UPDATED", "DUPLICATE_FLAGGED"
  detail    String?  // e.g. "NEW → CONTACTED", old notes value, etc.

  @@index([leadId, createdAt])
}

model ErrorLog {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  severity   String   // "error" | "warning" | "critical"
  type       String   // "client_js" | "server_api" | "form_validation" | "rate_limit" | "auth" | etc.
  message    String
  stack      String?
  path       String?
  ip         String?
  userAgent  String?
  metadata   String?  // JSON string

  @@index([createdAt])
  @@index([severity, createdAt])
  @@index([type, createdAt])
}

model PageView {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  path      String
  referrer  String?
  ip        String?
  userAgent String?
  sessionId String?
  duration  Int?     // milliseconds on page

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([sessionId, createdAt])
}

model FormEvent {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  sessionId String?
  eventType String   // "STARTED" | "FIELD_ERROR" | "ABANDONED" | "SUBMITTED"
  fieldName String?
  metadata  String?  // JSON string

  @@index([eventType, createdAt])
  @@index([sessionId, createdAt])
}
