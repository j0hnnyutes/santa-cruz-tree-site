// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
  ARCHIVED
}

model Lead {
  leadId       String      @id
  createdAt    DateTime    @default(now())
  fullName     String
  phoneDigits  String
  email        String

  address      String      @default("UNKNOWN")
  city         String      @default("UNKNOWN")

  service      String
  details      String?
  status       LeadStatus  @default(NEW)
  contactedAt  DateTime?
  adminNotes   String?
  archivedAt   DateTime?
  photoUrls    String[]    @default([])  // Vercel Blob URLs for customer-uploaded photos

  // UTM attribution — captured from query params at time of form submission
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?

  // Session linkage — joins to PageView.sessionId for conversion path analysis
  sessionId    String?

  // Audit trail
  events       LeadEvent[]
}

model LeadEvent {
  id        Int      @id @default(autoincrement())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [leadId], onDelete: Cascade)
  createdAt DateTime @default(now())
  action    String   // e.g. "CREATED", "STATUS_CHANGE", "NOTES_UPDATED", "DUPLICATE_FLAGGED"
  detail    String?  // e.g. "NEW → CONTACTED", old notes value, etc.

  @@index([leadId, createdAt])
}

model ErrorLog {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  severity   String   // "error" | "warning" | "critical"
  type       String   // "client_js" | "server_api" | "form_validation" | "rate_limit" | "auth" | etc.
  message    String
  stack      String?
  path       String?
  ip         String?
  userAgent  String?
  metadata   String?  // JSON string

  @@index([createdAt])
  @@index([severity, createdAt])
  @@index([type, createdAt])
}

model PageView {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  path        String
  referrer    String?
  ip          String?
  userAgent   String?
  sessionId   String?
  duration    Int?     // milliseconds on page
  utmSource   String?  // utm_source query param
  utmMedium   String?  // utm_medium query param
  utmCampaign String?  // utm_campaign query param
  country      String?  // ISO 3166-1 alpha-2 country code (from x-vercel-ip-country)
  region       String?  // state/region code (from x-vercel-ip-country-region)
  city         String?  // city name (from x-vercel-ip-city)
  isNewVisitor    Boolean? // true = first ever visit in this browser (via localStorage flag)
  maxScrollDepth  Int?     // 0–100 — furthest scroll % reached before leaving

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([sessionId, createdAt])
  @@index([utmSource, createdAt])
  @@index([country, createdAt])
}

model FormEvent {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  sessionId String?
  eventType String   // "STARTED" | "FIELD_ERROR" | "ABANDONED" | "SUBMITTED"
  fieldName String?
  metadata  String?  // JSON string

  @@index([eventType, createdAt])
  @@index([sessionId, createdAt])
}

// Pre-aggregated daily stats — populated by the nightly cron before raw
// PageView rows are purged. Preserves historical trends without retaining
// every individual pageview indefinitely.
model DailyRollup {
  id             Int    @id @default(autoincrement())
  date           String // "YYYY-MM-DD" (America/Los_Angeles local date)

  // Core metrics
  views          Int
  sessions       Int
  avgDuration    Int?   // average ms on page (null if no durations recorded)
  bounceCount    Int

  // Visitor type
  newSessions    Int    @default(0)
  returnSessions Int    @default(0)

  // Device split
  mobileViews    Int    @default(0)
  desktopViews   Int    @default(0)

  // Top-N lists stored as JSON strings (arrays, up to 10 entries each)
  topPages     String @default("[]") // [{path, views}]
  topReferrers String @default("[]") // [{referrer, views}]
  utmSources   String @default("[]") // [{source, medium, campaign, views}]

  archivedAt   DateTime @default(now())

  @@unique([date])
  @@index([date])
}

// Key-value store for admin configuration (e.g. password hash override)
model AdminConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
